{
  "name": "wristhop",
  "version": "1.0.0",
  "description": "WristHop (敲敲计) - HarmonyOS watch app for tap practice",
  "scripts": {
    "build:debug": "hvigorw assembleHap --mode module -p product=default -b debug",
    "build:release": "hvigorw assembleHap --mode module -p product=default -b release",
    "test": "hvigorw test --module entry",
    "lint": "code-linter lint",
    "clean": "rm -rf build/ entry/build/ node_modules/ oh_modules/",
    "dev": "hvigorw assembleHap --mode module -p product=default -b debug && hvigorw install"
  },
  "keywords": [
    "harmonyos",
    "arkts",
    "wearable",
    "health",
    "tap-care"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@ohos/hypium": "1.0.24",
    "@ohos/hamock": "1.0.0"
  }
}
