{
  "name": "wristhop",
  "version": "1.0.0",
  "description": "WristHop (敲敲计) - HarmonyOS watch app for tap practice",
  "scripts": {
    "build:debug": "hvigorw assembleHap --mode module -p product=default -b debug",
    "build:release": "hvigorw assembleHap --mode module -p product=default -b release",
    "test": "echo 'Use DevEco Studio to run HarmonyOS tests' && exit 0",
    "test:unit": "jest --config jest.config.js",
    "lint": "echo 'Use DevEco Studio code-linter' && exit 0",
    "clean": "rm -rf build/ entry/build/ node_modules/ oh_modules/",
    "dev": "echo 'Open in DevEco Studio and click Run button'",
    "setup": "./scripts/setup-dev.sh"
  },
  "keywords": [
    "harmonyos",
    "arkts",
    "wearable",
    "health",
    "tap-care"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "darwin",
    "win32",
    "linux"
  ]
}
